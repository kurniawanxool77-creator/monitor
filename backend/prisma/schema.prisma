// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== USER & AUTH ====================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  nama      String
  role      String   @default("USER") // SUPERADMIN, ADMIN, USER
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  activityLogs    ActivityLog[]
  realizations    Realization[]
  verifikasiDok   Verification[]

  @@map("users")
}

// ==================== BIDANG ====================

model Bidang {
  id        String   @id @default(uuid())
  kode      String   @unique
  nama      String
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  uraianList       Uraian[]
  subKegiatans     SubKegiatan[]

  @@map("bidang")
}

// ==================== URAIAN (Chart of Accounts) ====================

model Uraian {
  id           String   @id @default(uuid())
  kode         String
  nama         String
  level        Int      @default(1) // 1=Bidang, 2=Kegiatan, 3=SubKegiatan, 4=SubSubKegiatan
  parentId     String?
  pagu         Float    @default(0)
  activeYear   Int      @default(2024)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  parent       Uraian?  @relation("UraianHierarchy", fields: [parentId], references: [id])
  children     Uraian[] @relation("UraianHierarchy")
  bidang       Bidang?  @relation(fields: [bidangId], references: [id])
  bidangId     String?
  subKegiatans SubKegiatan[]

  @@unique([kode, activeYear])
  @@map("uraian")
}

// ==================== SUB KEGIATAN ====================

model SubKegiatan {
  id                    String   @id @default(uuid())
  uraianId              String
  bidangId              String
  nama                  String
  penanggungJawab       String
  sumberDana            String?
  anggaranSubKegiatan   Float    @default(0)
  tanggalMulai          DateTime
  tanggalSelesai        DateTime
  status                String   @default("PERSIAPAN") // PERSIAPAN, KOORDINASI, PELAKSANAAN, EVALUASI, VERIFIKASI, SELESAI
  isWadah               Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  uraian                Uraian  @relation(fields: [uraianId], references: [id])
  bidang                Bidang  @relation(fields: [bidangId], references: [id])
  steps                 Step[]
  realizations          Realization[]
  verifications         Verification[]
  logs                  ActivityLog[]

  @@map("sub_kegiatan")
}

// ==================== STEPS (Tahapan) ====================

model Step {
  id            String    @id @default(uuid())
  subKegiatanId String
  nama          String
  deskripsi     String?
  urutan        Int
  completed     Boolean   @default(false)
  completedAt   DateTime?
  catatan       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  subKegiatan    SubKegiatan @relation(fields: [subKegiatanId], references: [id], onDelete: Cascade)

  @@map("steps")
}

// ==================== REALISASI ANGGARAN ====================

model Realization {
  id              String   @id @default(uuid())
  subKegiatanId   String
  userId          String
  jumlah          Float
  keterangan      String?
  bulan           Int      // 1-12
  tahun           Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  subKegiatan     SubKegiatan @relation(fields: [subKegiatanId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id])

  @@map("realizations")
}

// ==================== VERIFIKASI DOKUMEN ====================

model Verification {
  id            String      @id @default(uuid())
  subKegiatanId String
  userId        String
  jenis         String      // FOTO, DOKUMEN, ABSENSI, LAPORAN
  nama          String
  fileUrl       String?
  status        String      @default("PENDING") // PENDING, APPROVED, REJECTED
  catatan       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  subKegiatan   SubKegiatan @relation(fields: [subKegiatanId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id])

  @@map("verifications")
}

// ==================== ACTIVITY LOG ====================

model ActivityLog {
  id            String   @id @default(uuid())
  userId        String
  subKegiatanId String?
  action        String
  details       String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  // Relations
  user          User        @relation(fields: [userId], references: [id])
  subKegiatan   SubKegiatan? @relation(fields: [subKegiatanId], references: [id])

  @@map("activity_logs")
}
